{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Gecko Security",
  "description": "Gecko Security documentation.",
  "appearance": {
    "default": "dark"
  },
  "colors": {
    "primary": "#171D29",
    "light": "#3B82F6",
    "dark": "#1B2230"
  },
  "background": {
    "color": {
      "light": "#F5F7FB",
      "dark": "#0D0D0D"
    }
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "quick-start",
              "how-gecko-works"
            ]
          },
          {
            "group": "Core concepts",
            "pages": [
              "concepts/findings",
              "concepts/scans",
              "concepts/repository-wiki",
              "concepts/api-spec"
            ]
          },
          {
            "group": "Connect your code",
            "pages": [
              "connect/github",
              "connect/gitlab",
              "connect/network-allowlist",
              "connect/webhooks",
              "connect/other-inputs"
            ]
          },
          {
            "group": "Scanning",
            "pages": [
              "scanning/run-a-scan",
              "scanning/pr-checks",
              "scanning/scheduled-scans",
              "scanning/rules",
              "scanner-settings"
            ]
          },
          {
            "group": "Triage & remediation",
            "pages": [
              "findings-remediation",
              "remediation/auto-fix-prs"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations",
              "jira-integration",
              "linear-integration",
              "slack-integration",
              "clickup-integration",
              "shortcut-integration",
              "gitlab-vulnerability-export",
              "defectdojo-integration"
            ]
          },
          {
            "group": "Administration",
            "pages": [
              "teams-permissions",
              "access/self-managed-sso",
              "access/saml",
              "access/okta-saml-onboarding",
              "admin/api-keys",
              "admin/audit-log",
              "admin/billing"
            ]
          },
          {
            "group": "Deployment",
            "pages": [
              "deployment/architecture"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Changelog",
            "pages": [
              "changelog"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Scans",
            "pages": [
              "GET /api/v1/scans",
              "POST /api/v1/scans",
              "GET /api/v1/scans/{scanId}/vulnerabilities",
              "GET /api/v1/scans/{scanId}/endpoints",
              "GET /api/v1/scans/{scanId}/wiki"
            ]
          },
          {
            "group": "Repositories",
            "pages": [
              "GET /api/v1/repositories",
              "GET /api/v1/repositories/{repositoryId}/vulnerabilities"
            ]
          },
          {
            "group": "Vulnerabilities",
            "pages": [
              "GET /api/v1/vulnerabilities"
            ]
          },
          {
            "group": "Utility",
            "pages": [
              "GET /api/v1/health"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.gecko.security",
          "icon": "house"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Feedback",
        "href": "mailto:gecko@gecko.security"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.gecko.security"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Gecko-Security",
      "x": "https://x.com/gecko_sec"
    }
  }
}
