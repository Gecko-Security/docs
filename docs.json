{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Gecko Security",
  "description": "Enterprise access docs for Gecko Security.",
  "appearance": {
    "default": "dark"
  },
  "colors": {
    "primary": "#171D29",
    "light": "#3B82F6",
    "dark": "#1B2230"
  },
  "background": {
    "color": {
      "light": "#F5F7FB",
      "dark": "#0D0D0D"
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quick-start",
              "development"
            ]
          },
          {
            "group": "Scanning",
            "pages": [
              "scanning-overview",
              "repository-scanning",
              "findings-remediation"
            ]
          },
          {
            "group": "Platform",
            "pages": [
              "teams-permissions",
              "scanner-settings"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations",
              "github-gitlab-integration",
              "jira-integration",
              "linear-integration",
              "slack-integration"
            ]
          },
          {
            "group": "Authentication",
            "pages": [
              "access/okta-saml-onboarding"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Scans",
            "pages": [
              "GET /api/v1/scans",
              "POST /api/v1/scans",
              "GET /api/v1/scans/{scanId}/vulnerabilities",
              "GET /api/v1/scans/{scanId}/endpoints",
              "GET /api/v1/scans/{scanId}/wiki"
            ]
          },
          {
            "group": "Repositories",
            "pages": [
              "GET /api/v1/repositories",
              "GET /api/v1/repositories/{repositoryId}/vulnerabilities"
            ]
          },
          {
            "group": "Vulnerabilities",
            "pages": [
              "GET /api/v1/vulnerabilities"
            ]
          },
          {
            "group": "Utility",
            "pages": [
              "GET /api/v1/health"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.gecko.security",
          "icon": "house"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Feedback",
        "href": "mailto:feedback@gecko.security"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.gecko.security"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Gecko-Security",
      "x": "https://x.com/gecko_sec"
    }
  }
}
